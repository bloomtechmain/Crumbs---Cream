# Server
PORT=5000
NODE_ENV=production

# Database — Railway provides DATABASE_URL automatically when you add a Postgres plugin.
# For local dev, fill in the individual fields below instead.
DATABASE_URL=

# Local dev DB (used when DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=crumbs_and_cream
DB_USER=postgres
DB_PASSWORD=postgres

# Auth
JWT_SECRET=replace_with_a_long_random_secret

# CORS — comma-separated list of allowed origins (leave blank in production when React is served by Express)
CORS_ORIGIN=
